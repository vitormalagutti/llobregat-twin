# Cache — parquet files are regenerated by the refresh job; never commit them
data/cache/*.parquet

# Streamlit secrets — never commit real credentials
.streamlit/secrets.toml

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
.env

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Pytest
.pytest_cache/
.coverage
htmlcov/

# Jupyter (if ever used for exploration)
.ipynb_checkpoints/
*.ipynb
